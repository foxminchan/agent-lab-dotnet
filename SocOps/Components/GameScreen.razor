@using SocOps.Models

<div class="win-desktop-game">
    <div class="win-window" style="flex: 1; display: flex; flex-direction: column;">

        <!-- Title Bar -->
        <div class="win-title-bar">
            <span class="win-title-text">&#xF4FF;&nbsp; SOC OPS &mdash; Social Bingo</span>
            <div class="win-title-buttons">
                <button class="win-title-btn" tabindex="-1" aria-hidden="true">&#x2501;</button>
                <button class="win-title-btn" tabindex="-1" aria-hidden="true">&#x25A1;</button>
                <button class="win-title-btn" tabindex="-1" aria-hidden="true">&#x2715;</button>
            </div>
        </div>

        <!-- Menu Bar -->
        <div class="win-menubar">
            <button @onclick="OnReset" class="win-menu-item">
                ← Back
            </button>
            <span class="win-menu-item">Game</span>
            <span class="win-menu-item">Help</span>
        </div>

        <!-- Bingo Banner -->
        @if (HasBingo)
        {
            <div class="win-bingo-banner">&#x2605;&#x2605;&#x2605; BINGO! YOU GOT A LINE! &#x2605;&#x2605;&#x2605;</div>
        }

        <!-- Board area -->
        <div class="win-client flex-1"
             style="display: flex; align-items: center; justify-content: center; padding: 0.5rem;">
            <BingoBoard Board="@Board" WinningSquareIds="@WinningSquareIds" OnSquareClick="@OnSquareClick" />
        </div>

        <!-- Status Bar -->
        <div class="win-status-bar">
            <button @onclick="OnReset" class="win-btn" style="padding: 1px 8px; font-size: 0.75rem; min-width: 0;">
                &#x2190; Back
            </button>
            <div class="win-status-panel">Tap a square when you find someone who matches it.</div>
        </div>

    </div>
</div>

@code {
    [Parameter]
    public List<BingoSquareData> Board { get; set; } = new();

    [Parameter]
    public HashSet<int> WinningSquareIds { get; set; } = new();

    [Parameter]
    public bool HasBingo { get; set; }

    [Parameter]
    public EventCallback<int> OnSquareClick { get; set; }

    [Parameter]
    public EventCallback OnReset { get; set; }
}
