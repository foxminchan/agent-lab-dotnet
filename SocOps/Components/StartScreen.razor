<div class="win-desktop">
    <div class="win-window" style="width: 100%; max-width: 22rem;">

        <!-- Title Bar -->
        <div class="win-title-bar">
            <span class="win-title-text">&#xF4FF;&nbsp; Soc Ops</span>
            <div class="win-title-buttons">
                <button class="win-title-btn" tabindex="-1" aria-hidden="true">&#x2501;</button>
                <button class="win-title-btn" tabindex="-1" aria-hidden="true">&#x25A1;</button>
                <button class="win-title-btn" tabindex="-1" aria-hidden="true">&#x2715;</button>
            </div>
        </div>

        <!-- Client Area -->
        <div class="win-client" style="padding: 1.25rem 1rem 1rem;">

            <!-- App title -->
            <div style="text-align: center; margin-bottom: 1rem;">
                <div style="font-family: var(--font-mono); font-size: 2.8rem; letter-spacing: 0.1em; line-height: 1;">SOC OPS</div>
                <div style="font-size: 0.75rem; letter-spacing: 0.12em; color: var(--win-shadow); margin-top: 2px;">SOCIAL BINGO v1.0</div>
            </div>

            <!-- How to Play group box -->
            <div class="win-group-box" style="margin-bottom: 1.25rem;">
                <span class="win-group-label">How to Play</span>
                <ul style="list-style: none; padding: 0; margin: 0; font-size: 0.8rem; line-height: 2;">
                    <li>&#x25B6;&nbsp; Find people who match the prompts</li>
                    <li>&#x25B6;&nbsp; Tap a square when you find a match</li>
                    <li>&#x25B6;&nbsp; Get 5 in a row to win!</li>
                </ul>
            </div>

            <!-- Start Button -->
            <div style="display: flex; justify-content: center;">
                <button
                    @onclick="OnStart"
                    class="win-btn win-btn-primary"
                    style="position: relative; width: 100%; padding: 8px 16px; font-size: 0.9rem;">
                    &#x25B6;&nbsp; Start Game
                </button>
            </div>
        </div>

    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnStart { get; set; }
}
